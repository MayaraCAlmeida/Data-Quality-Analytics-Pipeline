{
    "name": "Dashboard Financeiro Dark",
    "dataColors": [
        "#2ECC71",
        "#E67E22",
        "#9B59B6",
        "#E74C3C",
        "#3498DB",
        "#F1C40F"
    ],
    "background": "#1E1E1E",
    "foreground": "#FFFFFF",
    "tableAccent": "#2ECC71",
    "visualStyles": {
        "*": {
            "*": {
                "title": [
                    {
                        "color": {
                            "solid": {
                                "color": "#FFFFFF"
                            }
                        },
                        "fontSize": 14,
                        "fontFamily": "Segoe UI Semibold"
                    }
                ],
                "labels": [
                    {
                        "color": {
                            "solid": {
                                "color": "#EAEAEA"
                            }
                        },
                        "fontSize": 11
                    }
                ],
                "background": [
                    {
                        "color": {
                            "solid": {
                                "color": "#2A2A2A"
                            }
                        },
                        "transparency": 5
                    }
                ]
            }
        },
        "card": {
            "*": {
                "labels": [
                    {
                        "fontSize": 28,
                        "color": {
                            "solid": {
                                "color": "#FFFFFF"
                            }
                        }
                    }
                ],
                "categoryLabels": [
                    {
                        "fontSize": 12,
                        "color": {
                            "solid": {
                                "color": "#BBBBBB"
                            }
                        }
                    }
                ]
            }
        }
